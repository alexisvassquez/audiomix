# AudioMIX environment variables example
# Copy this file to .env and fill in with your own values.
# For cloning purposes
# Generate a token with: python -c "import secrets; print(secrets.token_hex(32))"
# Every time token is rotated, must be updated in both repos
# or WebSocket handshake will fail with 401s
AUDIOMIX_API_TOKEN=your_generated_token_here
AUDIOMIX_API_PORT=8000
AUDIOMIX_ENV=dev